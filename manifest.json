{
  "manifest_version": 3,
  "name": "Gmail Domain Colorizer",
  "version": "1.0.0",
  "description": "Colors Gmail inbox rows by sender domain.",
  "permissions": ["storage"],
  "host_permissions": ["https://mail.google.com/*"],
  "content_scripts": [
    {
      "js": ["scripts/content.js"],
      "matches": ["https://mail.google.com/*"]
    }
  ]
}
      
